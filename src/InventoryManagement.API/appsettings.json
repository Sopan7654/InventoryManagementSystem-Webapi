{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=inventory_db;User=root;Password=rootpassword;",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatShouldBeAtLeast32CharactersLong!@#",
    "Issuer": "InventoryManagement",
    "Audience": "InventoryManagementAPI",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "RedisSettings": {
    "ConnectionString": "localhost:6379",
    "DefaultExpiryMinutes": 10
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "AppSettings": {
    "ValuationMethod": "FIFO",
    "DefaultPageSize": 20,
    "MaxPageSize": 100
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": { "path": "Logs/log-.txt", "rollingInterval": "Day" }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
